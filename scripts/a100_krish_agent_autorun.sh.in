#!/usr/bin/env bash
set -euo pipefail

FULL_SHA="__FULL_SHA__"
SHORT_SHA="__SHORT_SHA__"
RUNNER_NAME="__RUNNER_NAME__"
RUNNER_TARBALL="__RUNNER_TARBALL__"
NEUROTWIN_DOCKER_IMAGE="__IMAGE_REF__"
MODE="${1:-synthetic50}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

usage() {
  cat <<EOF
usage: ./run_krish_agent.sh [synthetic50|synthetic100|algonauts-debug|full6|verify-only]

Default mode is synthetic50. Run order should be:
  1. synthetic50
  2. synthetic100 only if synthetic50 says needs_evidence
  3. algonauts-debug only after synthetic passes
  4. full6 only after algonauts-debug passes

Environment:
  GHCR_USER                     default: ptlnextdoor
  GHCR_TOKEN                    GHCR read token; prompted if missing and a TTY exists
  NEUROTWIN_DOCKER_IMAGE        default: $NEUROTWIN_DOCKER_IMAGE
  EXTRACT_ROOT                  default: ./runner-extracted
  RUN_ROOT                      mode-specific default under /raid/scratch/\$USER
  HOST_GPU_ID                   default: 0 for one-GPU modes
  HOST_GPU_IDS                  default: 0,1,2,3,4,5 for full6
  MATERIALIZED_CONFIG_ROOT      default: /raid/scratch/\$USER/materialized_configs
EOF
}

if [[ "${MODE}" == "-h" || "${MODE}" == "--help" ]]; then
  usage
  exit 0
fi

checksum_verify() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum -c SHA256SUMS
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 -c SHA256SUMS
  else
    echo "sha256sum or shasum is required." >&2
    exit 2
  fi
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "$1 is required." >&2
    exit 2
  fi
}

docker_login_and_pull() {
  need docker
  export NEUROTWIN_DOCKER_IMAGE="${NEUROTWIN_DOCKER_IMAGE:-${IMAGE_REF}}"
  GHCR_USER="${GHCR_USER:-ptlnextdoor}"
  if [[ "${NEUROTWIN_SKIP_GHCR_LOGIN:-0}" != "1" ]]; then
    if [[ -z "${GHCR_TOKEN:-}" ]]; then
      if [[ -t 0 ]]; then
        read -rsp "GHCR token for $GHCR_USER: " GHCR_TOKEN
        echo
      else
        echo "GHCR_TOKEN is required in non-interactive mode." >&2
        exit 2
      fi
    fi
    printf '%s' "$GHCR_TOKEN" | docker login ghcr.io -u "$GHCR_USER" --password-stdin
    unset GHCR_TOKEN
  fi
  docker pull "$NEUROTWIN_DOCKER_IMAGE"
}

extract_runner() {
  EXTRACT_ROOT="${EXTRACT_ROOT:-$SCRIPT_DIR/runner-extracted}"
  mkdir -p "$EXTRACT_ROOT"
  if [[ ! -d "$EXTRACT_ROOT/$RUNNER_NAME" ]]; then
    tar -xzf "$RUNNER_TARBALL" -C "$EXTRACT_ROOT"
  fi
  RUNNER_DIR="$EXTRACT_ROOT/$RUNNER_NAME"
  if [[ ! -d "$RUNNER_DIR" ]]; then
    echo "Runner extraction failed: $RUNNER_DIR" >&2
    exit 3
  fi
  (
    cd "$RUNNER_DIR"
    checksum_verify
    actual="$(cat COMMIT_HASH.txt)"
    if [[ "$actual" != "$FULL_SHA" ]]; then
      echo "Commit mismatch: expected $FULL_SHA, got $actual" >&2
      exit 3
    fi
  )
}

docker_eval_synthetic() {
  local steps=$1
  HOST_GPU_ID="${HOST_GPU_ID:-0}"
  RUN_ROOT="${RUN_ROOT:-/raid/scratch/$USER/neurotwin-nfc-synthetic-$SHORT_SHA-$steps}"
  mkdir -p "$RUN_ROOT"
  docker run --rm --gpus "\"device=${HOST_GPU_ID}\"" \
    --ipc=host --shm-size=64g \
    -e CUDA_VISIBLE_DEVICES=0 \
    -e RUN_ROOT="$RUN_ROOT" \
    -v "$RUN_ROOT":"$RUN_ROOT" \
    -v "$RUNNER_DIR":/workspace/repo \
    -w /workspace/repo \
    "$NEUROTWIN_DOCKER_IMAGE" \
    bash -lc 'set -euo pipefail
      python -m pip install -e ".[moabb,cluster]" >/tmp/neurotwin_pip_install.log
      python -m neurotwin.cli eval \
        --suite nfc_synthetic \
        --out-dir "$RUN_ROOT" \
        --train-steps '"$steps"' \
        --seeds 0 1 2'
  echo "run_root=$RUN_ROOT"
  echo "Inspect:"
  echo "  cat $RUN_ROOT/nfc_falsification_report.md"
  echo "  head -40 $RUN_ROOT/nfc_ablation_table.csv"
  echo "  head -40 $RUN_ROOT/uncertainty_calibration.csv"
}

docker_algonauts_debug() {
  HOST_GPU_ID="${HOST_GPU_ID:-0}"
  MATERIALIZED_CONFIG_ROOT="${MATERIALIZED_CONFIG_ROOT:-/raid/scratch/$USER/materialized_configs}"
  CONFIG="$MATERIALIZED_CONFIG_ROOT/algonauts_field_compiler_debug.yaml"
  RUN_ROOT="${RUN_ROOT:-/raid/scratch/$USER/neurotwin-algonauts-nfc-debug-$SHORT_SHA}"
  mkdir -p "$RUN_ROOT"
  if [[ ! -f "$CONFIG" ]]; then
    echo "Missing materialized config: $CONFIG" >&2
    exit 2
  fi
  docker run --rm --gpus "\"device=${HOST_GPU_ID}\"" \
    --ipc=host --shm-size=64g \
    -e CUDA_VISIBLE_DEVICES=0 \
    -e RUN_ROOT="$RUN_ROOT" \
    -v "$RUN_ROOT":"$RUN_ROOT" \
    -v "$RUNNER_DIR":/workspace/repo \
    -v "$MATERIALIZED_CONFIG_ROOT":"$MATERIALIZED_CONFIG_ROOT":ro \
    -w /workspace/repo \
    "$NEUROTWIN_DOCKER_IMAGE" \
    bash -lc 'set -euo pipefail
      python -m pip install -e ".[moabb,cluster]" >/tmp/neurotwin_pip_install.log
      PYTHON_BIN=python3 bash scripts/slurm/_train_a100_inner.sh "'"$CONFIG"'" "$RUN_ROOT" 1'
}

docker_full6() {
  MATERIALIZED_CONFIG_ROOT="${MATERIALIZED_CONFIG_ROOT:-/raid/scratch/$USER/materialized_configs}"
  export DOCKER_IMAGE="$NEUROTWIN_DOCKER_IMAGE"
  export HOST_GPU_IDS="${HOST_GPU_IDS:-0,1,2,3,4,5}"
  export GPU_COUNT="${GPU_COUNT:-6}"
  export NPROC_PER_NODE="${NPROC_PER_NODE:-6}"
  export CONTAINER_CUDA_VISIBLE_DEVICES="${CONTAINER_CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5}"
  export A100_CONFIG_TEMPLATE="${A100_CONFIG_TEMPLATE:-$MATERIALIZED_CONFIG_ROOT/algonauts_field_compiler_full.yaml}"
  export A100_RUN_ID="${A100_RUN_ID:-algonauts_nfc_full_$SHORT_SHA}"
  export PERSISTENT_ROOT="${PERSISTENT_ROOT:-/raid/scratch/$USER/neurotwin-$SHORT_SHA}"
  if [[ ! -f "$A100_CONFIG_TEMPLATE" ]]; then
    echo "Missing full config: $A100_CONFIG_TEMPLATE" >&2
    exit 2
  fi
  (
    cd "$RUNNER_DIR"
    bash scripts/run_docker_6gpu.sh "$PERSISTENT_ROOT"
  )
}

checksum_verify
extract_runner

case "$MODE" in
  verify-only)
    docker_login_and_pull
    echo "handoff_verified=true"
    echo "runner_dir=$RUNNER_DIR"
    echo "docker_image=$NEUROTWIN_DOCKER_IMAGE"
    ;;
  synthetic50)
    docker_login_and_pull
    docker_eval_synthetic 50
    ;;
  synthetic100)
    docker_login_and_pull
    docker_eval_synthetic 100
    ;;
  algonauts-debug)
    docker_login_and_pull
    docker_algonauts_debug
    ;;
  full6)
    docker_login_and_pull
    docker_full6
    ;;
  *)
    usage
    exit 2
    ;;
esac
